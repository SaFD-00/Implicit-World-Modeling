+        # diff token weighted loss: labels(-100) 마스크로 prefix/assistant 경계를 판단해 복원.
+        # n_asst >= n_w: template prefix(<think> 등)로 토큰이 늘면 뒤에서 정렬(offset).
+        # n_asst <  n_w: cutoff truncation으로 토큰이 줄면 앞에서부터 n_asst개만 사용.
+        if has_token_weights:
+            max_len = features["input_ids"].shape[1]
+            labels = features["labels"]
+            batch_weights = []
+            for i, w in enumerate(token_weights_list):
+                full_w = torch.ones(max_len, dtype=torch.float32)
+                full_w[labels[i] == IGNORE_INDEX] = 0.0
+                if w is not None:
+                    w = list(w)
+                    asst_indices = (labels[i] != IGNORE_INDEX).nonzero(as_tuple=True)[0]
+                    n_asst = len(asst_indices)
+                    n_w = len(w)
+                    if n_asst >= n_w:
+                        offset = n_asst - n_w
+                        for j in range(n_w):
+                            full_w[asst_indices[offset + j]] = w[j]
+                    else:
+                        for j in range(n_asst):
+                            full_w[asst_indices[j]] = w[j]
+                batch_weights.append(full_w)
+            features["token_weights"] = torch.stack(batch_weights)
+
         return features
 
 
