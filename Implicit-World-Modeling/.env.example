HF_TOKEN=your_huggingface_token_here
NPROC_PER_NODE=2    # node 당 GPU 수 (= torchrun world size, single node 기준). 허용: 1, 2, 4, 8.
GPU_TYPE=H100       # GPU 종류. 허용: RTX5090 (32GB), A100 (80GB), H100 (80GB). 노트북 Cell 5 가 size × GPU 표로 per_device_train_batch_size 결정.

# --- 원격 GPU 클러스터 제출 (A100/H100) ------------------------------------------
# scripts/remote_launch.sh + configs/remote/run.template.yaml 이 사용한다.
# 제공자 중립: 코드에 플랫폼 이름이 없다. 제출 커맨드는 REMOTE_SUBMIT_CMD 로 주입하고,
# run spec 스키마는 configs/remote/run.template.yaml 을 교체하면 바뀐다.
# 아래 10개는 전부 필수. 하나라도 비면 remote_launch.sh 가 누락 변수명을 나열하고 exit 1 한다.
REMOTE_ORG=your_org                        # 조직/네임스페이스
REMOTE_PROJECT=your_project                # 프로젝트
REMOTE_CLUSTER=your_cluster                # 실행 클러스터
REMOTE_GPU_TYPE=A100                       # A100 | H100. EXP05 stage1 full FT 는 80GB GPU 필수 (RTX5090 32GB 불가).
REMOTE_GPU_COUNT=2                         # 1 | 2 | 4 | 8. GPU 트리오는 gpu_policy.py 가 주입하므로 어느 값이든 GLOBAL_BATCH=64 유지.
REMOTE_IMAGE=                              # CUDA + conda 가 있는 컨테이너 이미지. 클러스터에서 쓸 수 있는 것으로 지정하라.
REMOTE_ARTIFACT_URI=                       # outputs/ 를 내보낼 아티팩트 저장소 URI
IWM_DATA_MOUNT=                            # AndroidControl/images + AndroidControl_EXP05/*.jsonl 을 담은 마운트 소스
IWM_GIT_URL=github.com/SaFD-00/Implicit-World-Modeling
IWM_GIT_REF=main                           # 스크립트가 실제로 존재하는 브랜치/커밋으로 맞춰라
# 선택: 제출 커맨드 템플릿. {spec} {org} {project} 가 치환된다. 비우면 렌더만 하고 제출하지 않는다.
# REMOTE_SUBMIT_CMD='<cli> run create -f {spec} --organization {org} --project {project}'
