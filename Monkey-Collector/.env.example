# OpenRouter (OpenAI-compatible Chat Completions). Used by `--input-mode api`
# (input text generation) and `--screen-grouping on` (screen element grouping).
OPENROUTER_API_KEY=sk-or-your-api-key-here
# Optional overrides (defaults shown):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=qwen/qwen3.7-plus

# Android SDK (used by `android` / `adb`)
# ANDROID_HOME=/opt/android/sdk

# Batch collection defaults
# MONKEY_APKS_DIR=./apks
# MONKEY_OUTPUT_DIR=./data/raw
